{
  "default": "iteration",
  "adapters": {
    "iteration": {
      "name": "iteration",
      "prompt_path": "core/prompts/iteration_specialist.md",
      "mode": "mutation",
      "guard_behavior": "iteration",
      "result_handling": {
        "result_mode": "mutation",
        "sanitize_apply_supported": true
      }
    },
    "outreach": {
      "name": "outreach",
      "prompt_path": "core/prompts/outreach_specialist.md",
      "mode": "generation",
      "guard_behavior": "passthrough",
      "result_handling": {
        "result_mode": "generation",
        "sanitize_apply_supported": false,
        "normalized_result_contract": {
          "contract_id": "normalized_generation_result.v1",
          "status": "target_only_not_enforced",
          "required_top_level_keys": [
            "mode",
            "iteration",
            "result",
            "notes"
          ],
          "field_requirements": {
            "mode": "must be the literal string 'generation'",
            "iteration": "must preserve input iteration metadata exactly as-is",
            "result": {
              "required_keys": [
                "status",
                "summary",
                "artifacts"
              ],
              "status_values": [
                "ok",
                "needs_input",
                "blocked"
              ],
              "artifacts_item_shape": [
                "name",
                "type",
                "content"
              ]
            },
            "notes": "array of strings"
          }
        }
      }
    },
    "reputationops": {
      "name": "reputationops",
      "prompt_path": "core/prompts/reputationops_specialist.md",
      "mode": "pipeline",
      "guard_behavior": "passthrough",
      "result_handling": {
        "result_mode": "pipeline",
        "sanitize_apply_supported": false
      }
    }
  }
}

{
  "components": [
    {
      "emits": {
        "showDetail": "Review"
      },
      "id": "review_list",
      "props": {
        "reviews": "Review[]"
      },
      "purpose": "Display a list of reviews"
    },
    {
      "emits": {},
      "id": "review_detail_panel",
      "props": {
        "selectedReview": "Review"
      },
      "purpose": "Show details of a selected review"
    },
    {
      "emits": {
        "preview": "string",
        "send": "ReplyDraft"
      },
      "id": "reply_editor",
      "props": {
        "draft": "ReplyDraft",
        "sentiment": "Sentiment"
      },
      "purpose": "Allow writing and previewing replies"
    },
    {
      "emits": {
        "complete": "string"
      },
      "id": "action_item_list",
      "props": {
        "items": "ActionItem[]"
      },
      "purpose": "List of action items related to a review"
    },
    {
      "emits": {
        "filterChange": "string[]"
      },
      "id": "filter_bar",
      "props": {
        "options": "string[]"
      },
      "purpose": "Provide filtering options for the reviews"
    },
    {
      "emits": {
        "saveSettings": "object"
      },
      "id": "settings_form",
      "props": {
        "config": "object"
      },
      "purpose": "Allow users to configure review preferences"
    },
    {
      "emits": {
        "toggleDarkMode": "boolean"
      },
      "id": "dark_mode_toggle",
      "props": {
        "isDarkModeEnabled": "boolean"
      },
      "purpose": "Toggle dark mode on and off"
    }
  ]
}

#!/usr/bin/env bash
set -euo pipefail

TICKET_FILE="${1:?usage: run_iteration_once.sh /path/to/ticket.txt}"

RAW="/tmp/iter_raw_$(date +%s).json"
TXT="/tmp/iter_payload_text_$(date +%s).txt"
NORM="/tmp/iter_normalized_$(date +%s).json"

SID="$(python3 - <<'PY'
import uuid
print(uuid.uuid4())
PY
)"

openclaw agent --agent iteration --local --json --session-id "$SID" -m "$(cat "$TICKET_FILE")" > "$RAW"

python3 - <<PY
import json
raw_path="$RAW"
txt_path="$TXT"
with open(raw_path,"r",encoding="utf-8") as f:
    data=json.load(f)
payloads=data.get("payloads") or []
text = payloads[0].get("text","") if payloads else ""
with open(txt_path,"w",encoding="utf-8") as f:
    f.write(text)
print(f"WROTE_PAYLOAD_TEXT bytes={len(text)} payloads={len(payloads)} file={txt_path}")
PY

~/.openclaw/workspace-exec/iter_gate.sh "$TXT" > "$NORM"
echo "NORMALIZED_JSON_FILE=$NORM"
python3 ~/.openclaw/workspace-exec/iter_path_allowlist.py --allowlist ~/.openclaw/workspace-exec/canonical_pack_paths.txt --normalized "$NORM"
python3 ~/.openclaw/workspace-exec/iter_approve.py --policy P1 --raw-text-file "$TXT" --normalized-json-file "$NORM"

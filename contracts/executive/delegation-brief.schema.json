{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Executive Delegation Brief",
  "type": "object",
  "required": [
    "delegation_id",
    "task_id",
    "assigned_specialist",
    "objective",
    "deliverable",
    "constraints",
    "non_goals",
    "acceptance_criteria",
    "tool_policy",
    "output_requirements"
  ],
  "properties": {
    "delegation_id": {
      "type": "string"
    },
    "task_id": {
      "type": "string"
    },
    "assigned_specialist": {
      "type": "string"
    },
    "objective": {
      "type": "string"
    },
    "deliverable": {
      "type": "string"
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "non_goals": {
      "type": "array",
      "items": { "type": "string" }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": { "type": "string" }
    },
    "tool_policy": {
      "type": "object",
      "required": [
        "allowed_tools",
        "disallowed_tools",
        "internet",
        "file_mutation",
        "allowed_paths",
        "background_execution"
      ],
      "properties": {
        "allowed_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "disallowed_tools": {
          "type": "array",
          "items": { "type": "string" }
        },
        "internet": {
          "type": "string",
          "enum": ["off", "on_within_scope", "propose_only"]
        },
        "file_mutation": {
          "type": "string",
          "enum": ["none", "restricted", "allowed"]
        },
        "allowed_paths": {
          "type": "array",
          "items": { "type": "string" }
        },
        "background_execution": {
          "type": "string",
          "enum": ["off", "propose_only", "on_within_scope"]
        }
      }
    },
    "output_requirements": {
      "type": "array",
      "items": { "type": "string" }
    },
    "escalation_conditions": {
      "type": "array",
      "items": { "type": "string" }
    },
    "created_at": {
      "type": "string"
    }
  }
}
